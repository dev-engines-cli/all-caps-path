{
  "name": "all-caps-path",
  "type": "module",
  "version": "0.3.0",
  "scripts": {
    "test": "vitest run --coverage",
    "unit": "vitest --coverage",
    "lint": "eslint *.js src tests",
    "fix": "npm run lint -- --fix",
    "bump": "npx --yes -- @jsdevtools/version-bump-prompt@latest && npm i",
    "outdated": "npm outdated"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-tjw-base": "^5.0.0",
    "eslint-config-tjw-import-x": "^1.0.1",
    "eslint-config-tjw-jest": "^4.0.0",
    "eslint-config-tjw-jsdoc": "^2.0.1",
    "eslint-import-resolver-vite": "^2.2.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-jsdoc": "^63.0.10",
    "globals": "^17.7.0",
    "memfs": "^4.57.8",
    "vitest": "^4.1.4"
  },
  "private": false,
  "files": [
    "index.js",
    "src"
  ],
  "main": "index.js",
  "module": "./index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./index.js"
    },
    "./index.js": {
      "import": "./index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dev-engines-cli/all-caps-path.git"
  },
  "author": "The Jared Wilcurt",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dev-engines-cli/all-caps-path/issues"
  },
  "homepage": "https://github.com/dev-engines-cli/all-caps-path#readme",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "25.9.0"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.12.1"
    }
  }
}
